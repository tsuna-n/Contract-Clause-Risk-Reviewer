# Copy to .env and fill in the real values. Never commit .env itself.
#
#   cp .env.example .env
#
# Values below are the localhost defaults for running the backend directly.
# docker compose overrides the host-dependent ones (DATABASE_URL, REDIS_URL,
# GOOGLE_REDIRECT_URI, FRONTEND_URL) with container-network addresses, so you
# only need to fill in the secrets.

# --- core ---------------------------------------------------------------
# NOTE: the +psycopg driver is required. A bare postgresql:// URL resolves to
# psycopg2, which this project does not install, and every DB call will fail.
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/contract_risk_db
APP_ENV=development

# --- auth: Google OAuth + JWT -------------------------------------------
# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth client.
# The redirect URI must be registered there verbatim.
GOOGLE_OAUTH_API=your-client-id.apps.googleusercontent.com
GOOGLE_KEY_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Origin of the frontend. Doubles as the CORS allow-list, so a mismatch here
# is what makes the browser block every API call.
FRONTEND_URL=http://localhost:5173

# Generate each with: openssl rand -hex 32
SESSION_SECRET_KEY=change-me-generate-a-random-32-byte-hex-string
JWT_SECRET_KEY=change-me-generate-a-different-random-32-byte-hex-string
JWT_ALGORITHM=HS256
# One working day (12h). Logout is client-side only — the token stays valid
# until it expires — so this doubles as the blast radius of a leaked token.
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- llm: Google GenAI / Gemini -----------------------------------------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
LLM_MODEL=gemini-3.5-flash
# Ceiling for a SINGLE Gemini call, not for a whole review (one review makes
# several calls per clause). Without it, one hung call pins a worker forever.
LLM_TIMEOUT_SECONDS=120

# --- rag / storage ------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
EMBEDDING_MODEL=gemini-embedding-001
# Must match the vector column width in the Alembic migration. Changing this
# requires a new migration and re-ingesting the playbook.
EMBEDDING_DIM=768

# --- feature flags ------------------------------------------------------
ENABLE_JUDGE=true
ENABLE_HYBRID_RETRIEVAL=true
# How long uploaded contracts and reports live in Redis (seconds).
# Overriding a clause reloads the report by id, so this is really "how long
# can someone step away and still adjust their results". 8h covers a working
# day; keep it below ACCESS_TOKEN_EXPIRE_MINUTES so the session always
# outlives the data it points at.
RETENTION_TTL_SECONDS=28800
